# =============================================================================
# Stripe — powers “Continue to payment” on https://yamunaretreats.com/shop/cart
# =============================================================================
#
# 1. Open Stripe Dashboard → Developers → API keys:
#    https://dashboard.stripe.com/apikeys
# 2. Copy the Secret key (starts with sk_test_ for test mode, sk_live_ for live).
# 3. In Vercel: your project → Settings → Environment Variables:
#    - Name:  STRIPE_SECRET_KEY
#    - Value: paste the secret key
#    - Environment: Production (and Preview if you want test checkouts on previews)
# 4. Save, then trigger a new deployment (Redeploy) so the serverless function picks it up.
#
# Test mode: use sk_test_… and test card 4242 4242 4242 4242 in Checkout.
# Live mode:  use sk_live_… only after you’re ready to charge real cards.

STRIPE_SECRET_KEY=sk_test_51...

# Used for success/cancel redirect URLs when the request has no Origin (some proxies).
# Set to your public storefront URL (no trailing slash).
SITE_URL=https://yamunaretreats.com

# -----------------------------------------------------------------------------
# Optional — only if your API is not on the same domain as the React app
# -----------------------------------------------------------------------------
# VITE_STRIPE_CHECKOUT_URL=https://yamunaretreats.com/api/create-checkout-session

# -----------------------------------------------------------------------------
# Homepage hero video (optional overrides)
# -----------------------------------------------------------------------------
# VITE_HERO_VIDEO_URL=https://… full URL to main MP4
# VITE_HERO_VIDEO_URL_MOBILE=https://… smaller MP4 for max-width 767px (faster on iPhone)
